---
import Base from '../layouts/Base.astro';
---

<Base title="Contribuciones Odoo — Christihan Laurel" description="822 contribuciones a Odoo Core, Enterprise y OCA. Desglose completo de aportes como Fullstack Odoo Developer en Vauxoo.">
  <main class="contrib-page">
    <div class="container">
      <a href="/" class="back-link">← Volver al inicio</a>
      <span class="section-label">Vauxoo · Odoo Gold Partner</span>
      <h1 class="section-title">822 contribuciones a Odoo</h1>
      <p class="hero-subtitle">Fullstack Odoo Developer · 647 fusionadas (78.7% aceptación) · 3 plataformas</p>

      <div class="stats-banner">
        <div class="big-stat">
          <span class="big-num">822</span>
          <span class="big-label">Aportes totales</span>
        </div>
        <div class="big-stat">
          <span class="big-num">78.7%</span>
          <span class="big-label">Merge rate</span>
        </div>
        <div class="big-stat">
          <span class="big-num">466</span>
          <span class="big-label">Git Vauxoo</span>
        </div>
        <div class="big-stat">
          <span class="big-num">183</span>
          <span class="big-label">GitHub</span>
        </div>
        <div class="big-stat">
          <span class="big-num">173</span>
          <span class="big-label">GitLab.com</span>
        </div>
        <div class="big-stat review-stat">
          <span class="big-num">226</span>
          <span class="big-label">Revisiones técnicas</span>
        </div>
      </div>

      <div class="section-card">
        <h2>Distribución por tipo</h2>
        <div class="type-bars">
          <div class="type-bar">
            <span class="type-label">Mejoras</span>
            <div class="bar-track"><div class="bar-fill" style="width: 50%"></div></div>
            <span class="type-count">410</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Bugfixes</span>
            <div class="bar-track"><div class="bar-fill" style="width: 22.5%"></div></div>
            <span class="type-count">185</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Migraciones</span>
            <div class="bar-track"><div class="bar-fill" style="width: 10.3%"></div></div>
            <span class="type-count">85</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Features</span>
            <div class="bar-track"><div class="bar-fill" style="width: 4.9%"></div></div>
            <span class="type-count">40</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Refactor</span>
            <div class="bar-track"><div class="bar-fill" style="width: 2.7%"></div></div>
            <span class="type-count">22</span>
          </div>
        </div>
      </div>

      <div class="section-card">
        <h2>Top módulos Odoo modificados</h2>
        <div class="module-list">
          <div class="module-item"><span class="module-name">islamicrelief</span><span class="module-count">45</span></div>
          <div class="module-item"><span class="module-name">vauxoo (core interno)</span><span class="module-count">30</span></div>
          <div class="module-item"><span class="module-name">nortenas</span><span class="module-count">24</span></div>
          <div class="module-item"><span class="module-name">internal_transfer_with_agreed_amount</span><span class="module-count">8</span></div>
          <div class="module-item"><span class="module-name">website_sale_subscription</span><span class="module-count">2</span></div>
        </div>
      </div>

      <div class="section-card">
        <h2>Contribuciones OCA destacadas</h2>
        <ul class="oca-list">
          <li><strong>purchase_order_archive</strong> — Migración a 16.0</li>
          <li><strong>account_move_name_sequence</strong> — Migración a 18.0</li>
          <li><strong>purchase_analytic</strong> — Migración a 17.0 y 18.0</li>
          <li><strong>product_pricelist_supplierinfo</strong> — Migración a 18.0 + mejoras</li>
          <li><strong>report_qweb_encrypt</strong> — Migración a 18.0</li>
          <li><strong>stock_picking_analytic</strong> — Mejora rendimiento</li>
          <li><strong>partner_ref_vat_unique</strong> — Búsqueda por VAT</li>
          <li><strong>project_task_code</strong> — Búsqueda por número de tarea</li>
          <li><strong>sale_commission</strong> — Migración + bugfixes</li>
        </ul>
      </div>

      <div class="section-card">
        <h2>Repositorios con mayor actividad</h2>
        <div class="repo-section-label">
          <span class="repo-badge private">Privados</span>
        </div>
        <div class="repo-list">
          <div class="repo-item">
            <span class="repo-name">ircanada/ircodoo</span>
            <span class="repo-count">163 aportes</span>
            <span class="repo-desc">Odoo Core Canadá</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">vauxoo/instance</span>
            <span class="repo-count">43 aportes</span>
            <span class="repo-desc">Gestión de instancias Odoo</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">vauxoo/nortenas</span>
            <span class="repo-count">26 aportes</span>
            <span class="repo-desc">Integración Norteñas</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">vauxoo/islamicrelief</span>
            <span class="repo-count">45 aportes</span>
            <span class="repo-desc">Módulo interno Vauxoo</span>
          </div>
        </div>
        <div class="repo-section-label" style="margin-top:20px">
          <span class="repo-badge public">Públicos</span>
        </div>
        <div class="repo-list">
          <div class="repo-item">
            <span class="repo-name">odoo/odoo</span>
            <span class="repo-count">22 aportes</span>
            <span class="repo-desc">Odoo Core (forward-ports)</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">odoo/enterprise</span>
            <span class="repo-count">22 aportes</span>
            <span class="repo-desc">Odoo Enterprise</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">OCA (varios)</span>
            <span class="repo-count">77 aportes</span>
            <span class="repo-desc">9 módulos de la asociación</span>
          </div>
        </div>
      </div>

      <div class="section-card" id="publicos">
        <h2>193 contribuciones públicas</h2>
        <p class="section-desc">Aportes open source en GitHub y GitLab público. Odoo Core, Enterprise, OCA y otros repositorios.</p>
        <div class="public-grid">
          <div class="public-group">
            <h3>Odoo Core & Enterprise</h3>
            <div class="public-bar"><span class="pub-label">odoo/odoo</span><span class="pub-count">22</span><span class="pub-desc">Forward-ports y bugfixes</span></div>
            <div class="public-bar"><span class="pub-label">odoo/enterprise</span><span class="pub-count">22</span><span class="pub-desc">Bugfixes y migraciones</span></div>
            <div class="public-total"><span>44 total</span></div>
          </div>
          <div class="public-group">
            <h3>OCA (Odoo Community Association)</h3>
            <div class="public-bar"><span class="pub-label">purchase_order_archive</span><span class="pub-count">—</span><span class="pub-desc">Migración 16.0</span></div>
            <div class="public-bar"><span class="pub-label">account_move_name_sequence</span><span class="pub-count">—</span><span class="pub-desc">Migración 18.0</span></div>
            <div class="public-bar"><span class="pub-label">purchase_analytic</span><span class="pub-count">—</span><span class="pub-desc">Migración 17.0 y 18.0</span></div>
            <div class="public-bar"><span class="pub-label">product_pricelist_supplierinfo</span><span class="pub-count">—</span><span class="pub-desc">Migración 18.0 + mejoras</span></div>
            <div class="public-bar"><span class="pub-label">Otros 5 módulos</span><span class="pub-count">—</span><span class="pub-desc">Encrypt, analytic, vat, task, commission</span></div>
            <div class="public-total"><span>77 total</span></div>
          </div>
          <div class="public-group">
            <h3>Otros repos públicos</h3>
            <div class="public-bar"><span class="pub-label">GitHub varios</span><span class="pub-count">72</span><span class="pub-desc">Issues, forks y PRs menores</span></div>
            <div class="public-total"><span>72 total</span></div>
          </div>
        </div>
        <div class="public-summary">
          <p>Tasa de merge en aportes públicos: <strong>78.7%</strong></p>
        </div>
      </div>

      <div class="section-card">
        <h2>226 revisiones técnicas realizadas</h2>
        <div class="review-section">
          <p class="review-intro">MRs/PRs donde participé como reviewer formal o mediante LGTM.</p>
          <div class="review-bar">
            <span class="rev-label">ircanada/ircodoo</span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:83.2%"></div></div>
            <span class="rev-count">188</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">Vauxoo (int.)</span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:7.5%"></div></div>
            <span class="rev-count">17</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">GitHub.com</span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:4%"></div></div>
            <span class="rev-count">9</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">apps-purchased</span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:3.5%"></div></div>
            <span class="rev-count">8</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">ircodoo-dev</span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:1.8%"></div></div>
            <span class="rev-count">4</span>
          </div>
        </div>
      </div>

      <div class="gist-link">
        <p>¿Quieres ver el desglose completo con los 822 PRs/MRs, fechas y enlaces?</p>
        <a href="https://gist.github.com/Christihan-LB/2d7c7729d02ac56cefa4d0d5e0cedc94" target="_blank" class="btn btn-primary">
          Ver Gist completo →
        </a>
      </div>
    </div>
  </main>
</Base>

<style>
  .contrib-page {
    padding: 120px 0 64px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 48px;
  }

  .stats-banner {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .review-stat {
    border-color: #22c55e !important;
  }

  .review-stat .big-num {
    color: #22c55e !important;
  }

  .big-stat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 16px;
    text-align: center;
  }

  .big-num {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .big-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .section-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    margin-bottom: 24px;
  }

  .section-card h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .type-bars {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .type-bar {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .type-label {
    width: 100px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .bar-track {
    flex: 1;
    height: 12px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 6px;
  }

  .type-count {
    width: 48px;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .module-list, .repo-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .module-item, .repo-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 16px;
    background: var(--bg);
    border-radius: 8px;
  }

  .module-name, .repo-name {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .module-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 700;
  }

  .repo-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 700;
  }

  .repo-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .review-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .review-intro {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .review-bar {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .rev-label {
    width: 160px;
    font-size: 0.85rem;
    font-weight: 500;
    text-align: right;
    flex-shrink: 0;
  }

  .rev-count {
    width: 48px;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #22c55e;
    font-weight: 700;
  }

  .rev-fill {
    background: #22c55e !important;
  }

  .oca-list {
    list-style: none;
    padding: 0;
  }

  .oca-list li {
    padding: 8px 0;
    font-size: 0.95rem;
    border-bottom: 1px solid var(--border);
  }

  .oca-list li:last-child {
    border-bottom: none;
  }

  .oca-list li strong {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .gist-link {
    text-align: center;
    padding: 40px 0;
  }

  .gist-link p {
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .section-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .public-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .public-group h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .public-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 0;
    font-size: 0.85rem;
  }

  .pub-label {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    flex: 1;
  }

  .pub-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    width: 28px;
    text-align: right;
  }

  .pub-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .public-total {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .public-total span {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .public-summary {
    margin-top: 24px;
    padding: 14px 18px;
    background: rgba(99, 102, 241, 0.05);
    border-radius: 8px;
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .public-summary strong {
    color: var(--accent);
  }

  .repo-section-label {
    margin-bottom: 10px;
  }

  .repo-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-mono);
  }

  .repo-badge.private {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }

  .repo-badge.public {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  @media (max-width: 768px) {
    .stats-banner {
      grid-template-columns: repeat(3, 1fr);
    }

    .public-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .stats-banner {
      grid-template-columns: repeat(2, 1fr);
    }
    .type-label {
      width: auto;
      min-width: 60px;
      font-size: 0.8rem;
    }
    .type-bar {
      gap: 8px;
    }
    .type-count {
      width: 36px;
      font-size: 0.8rem;
    }
    .module-item, .repo-item {
      flex-wrap: wrap;
    }
    .rev-label {
      width: 100px;
      font-size: 0.75rem;
    }
  }
</style>
