---
import Base from '../layouts/Base.astro';
---

<Base title="Contribuciones Odoo — Christihan Laurel" description="822 contribuciones a Odoo Core, Enterprise y OCA. Desglose completo de aportes como Fullstack Odoo Developer en Vauxoo.">
  <main class="contrib-page">
    <div class="container">
      <a href="/" class="back-link">← Volver al inicio</a>
      <span class="section-label">Vauxoo · Odoo Gold Partner</span>
      <h1 class="section-title">822 contribuciones a Odoo</h1>
      <p class="hero-subtitle">Fullstack Odoo Developer · 647 fusionadas (78.7% aceptación) · 3 plataformas</p>

      <div class="stats-banner">
        <div class="big-stat">
          <span class="big-num">822</span>
          <span class="big-label">Aportes totales</span>
        </div>
        <div class="big-stat">
          <span class="big-num">78.7%</span>
          <span class="big-label">Merge rate</span>
        </div>
        <div class="big-stat">
          <span class="big-num">466</span>
          <span class="big-label">Git Vauxoo</span>
        </div>
        <div class="big-stat">
          <span class="big-num">183</span>
          <span class="big-label">GitHub</span>
        </div>
        <div class="big-stat">
          <span class="big-num">173</span>
          <span class="big-label">GitLab.com</span>
        </div>
        <div class="big-stat review-stat">
          <span class="big-num">226</span>
          <span class="big-label">Revisiones técnicas</span>
        </div>
      </div>

      <div class="section-card">
        <h2>Distribución por tipo</h2>
        <div class="type-bars">
          <div class="type-bar">
            <span class="type-label">Mejoras</span>
            <div class="bar-track"><div class="bar-fill" style="width: 50%"></div></div>
            <span class="type-count">410</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Bugfixes</span>
            <div class="bar-track"><div class="bar-fill" style="width: 22.5%"></div></div>
            <span class="type-count">185</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Migraciones</span>
            <div class="bar-track"><div class="bar-fill" style="width: 10.3%"></div></div>
            <span class="type-count">85</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Features</span>
            <div class="bar-track"><div class="bar-fill" style="width: 4.9%"></div></div>
            <span class="type-count">40</span>
          </div>
          <div class="type-bar">
            <span class="type-label">Refactor</span>
            <div class="bar-track"><div class="bar-fill" style="width: 2.7%"></div></div>
            <span class="type-count">22</span>
          </div>
        </div>
      </div>

      <div class="section-card">
        <h2>Top módulos Odoo modificados</h2>
        <div class="module-list">
          <div class="module-item"><span class="module-name">islamicrelief</span><span class="module-count">45</span></div>
          <div class="module-item"><span class="module-name">vauxoo (core interno)</span><span class="module-count">30</span></div>
          <div class="module-item"><span class="module-name">nortenas</span><span class="module-count">24</span></div>
          <div class="module-item"><span class="module-name">internal_transfer_with_agreed_amount</span><span class="module-count">8</span></div>
          <div class="module-item"><span class="module-name">website_sale_subscription</span><span class="module-count">2</span></div>
        </div>
      </div>

      <div class="section-card">
        <h2>Contribuciones OCA destacadas</h2>
        <ul class="oca-list">
          <li><strong>purchase_order_archive</strong> — Migración a 16.0</li>
          <li><strong>account_move_name_sequence</strong> — Migración a 18.0</li>
          <li><strong>purchase_analytic</strong> — Migración a 17.0 y 18.0</li>
          <li><strong>product_pricelist_supplierinfo</strong> — Migración a 18.0 + mejoras</li>
          <li><strong>report_qweb_encrypt</strong> — Migración a 18.0</li>
          <li><strong>stock_picking_analytic</strong> — Mejora rendimiento</li>
          <li><strong>partner_ref_vat_unique</strong> — Búsqueda por VAT</li>
          <li><strong>project_task_code</strong> — Búsqueda por número de tarea</li>
          <li><strong>sale_commission</strong> — Migración + bugfixes</li>
        </ul>
      </div>

      <div class="section-card">
        <h2>Repositorios con mayor actividad</h2>
        <div class="repo-section-label">
          <span class="repo-badge private">Privados</span>
        </div>
        <div class="repo-list">
          <div class="repo-item">
            <span class="repo-name">ircanada/ircodoo</span>
            <span class="repo-count">163 aportes</span>
            <span class="repo-desc">Odoo Core Canadá</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">vauxoo/instance</span>
            <span class="repo-count">43 aportes</span>
            <span class="repo-desc">Gestión de instancias Odoo</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">vauxoo/nortenas</span>
            <span class="repo-count">26 aportes</span>
            <span class="repo-desc">Integración Norteñas</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">vauxoo/islamicrelief</span>
            <span class="repo-count">45 aportes</span>
            <span class="repo-desc">Módulo interno Vauxoo</span>
          </div>
        </div>
        <div class="repo-section-label" style="margin-top:20px">
          <span class="repo-badge public">Públicos</span>
        </div>
        <div class="repo-list">
          <div class="repo-item">
            <span class="repo-name">odoo/odoo</span>
            <span class="repo-count">22 aportes</span>
            <span class="repo-desc">Odoo Core (forward-ports)</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">odoo/enterprise</span>
            <span class="repo-count">22 aportes</span>
            <span class="repo-desc">Odoo Enterprise</span>
          </div>
          <div class="repo-item">
            <span class="repo-name">OCA (varios)</span>
            <span class="repo-count">77 aportes</span>
            <span class="repo-desc">9 módulos de la asociación</span>
          </div>
        </div>
      </div>

      <div class="section-card" id="publicos">
        <h2>193 contribuciones públicas</h2>
        <p class="section-desc">Aportes open source en GitHub. Odoo Core, Odoo Enterprise, OCA y otros repositorios. Datos extraídos del <a href="https://gist.github.com/Christihan-LB/2d7c7729d02ac56cefa4d0d5e0cedc94" target="_blank">Gist de contribuciones</a>.</p>

        <div class="public-group">
          <h3>Odoo Core & Enterprise <span class="pub-total">44</span></h3>
          <div class="pub-pr-list">
            <div class="pub-pr">
              <a href="https://github.com/odoo/odoo/pulls?q=is%3Apr+author%3ACLaurelB" target="_blank" class="pub-pr-link">odoo/odoo</a>
              <span class="pub-pr-count">22 PRs</span>
              <span class="pub-pr-desc">Forward-ports y bugfixes a Odoo Core</span>
            </div>
            <div class="pub-pr">
              <a href="https://github.com/odoo/enterprise/pulls?q=is%3Apr+author%3ACLaurelB" target="_blank" class="pub-pr-link">odoo/enterprise</a>
              <span class="pub-pr-count">22 PRs</span>
              <span class="pub-pr-desc">Forward-ports y bugfixes a Enterprise</span>
            </div>
          </div>
          <div class="pub-gist-link">
            <a href="https://gist.github.com/Christihan-LB/2d7c7729d02ac56cefa4d0d5e0cedc94#file-2_aportes_desglosado-md" target="_blank">Ver PRs individuales en el Gist →</a>
          </div>
        </div>

        <div class="public-group">
          <h3>OCA · Odoo Community Association <span class="pub-total">~77</span></h3>
          <div class="pub-pr-list">
            <div class="pub-pr">
              <span class="pub-pr-link">purchase_order_archive</span>
              <span class="pub-pr-count">1</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/purchase-workflow/pull/1993" target="_blank">Migración a 16.0</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">account_move_name_sequence</span>
              <span class="pub-pr-count">1</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/account-financial-tools/pull/2016" target="_blank">Migración a 18.0</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">purchase_analytic</span>
              <span class="pub-pr-count">3</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/account-analytic/pulls?q=is%3Apr+author%3ACLaurelB" target="_blank">Migraciones a 17.0 y 18.0</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">product_pricelist_supplierinfo</span>
              <span class="pub-pr-count">4</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/product-attribute/pulls?q=is%3Apr+author%3ACLaurelB" target="_blank">Migración 18.0 + mejoras</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">report_qweb_encrypt</span>
              <span class="pub-pr-count">1</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/reporting-engine/pull/1066" target="_blank">Migración a 18.0</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">stock_picking_analytic</span>
              <span class="pub-pr-count">1</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/account-analytic/pull/660" target="_blank">Mejora rendimiento</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">sale_commission + sale_commission_salesman</span>
              <span class="pub-pr-count">4</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/commission/pulls?q=is%3Apr+author%3ACLaurelB" target="_blank">Migración 17.0 + bugfixes</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">odoo-module-migrator</span>
              <span class="pub-pr-count">4</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/odoo-module-migrator/pulls?q=is%3Apr+author%3ACLaurelB" target="_blank">Renamed fields para migraciones</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">partner_ref_vat_unique + project_task_code</span>
              <span class="pub-pr-count">3</span>
              <span class="pub-pr-desc"><a href="https://github.com/OCA/partner-contact/pull/1691" target="_blank">Búsqueda por VAT</a> · <a href="https://github.com/OCA/project/pull/1246" target="_blank">Búsqueda por tarea</a></span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">product_analytic + server_action_mass_edit</span>
              <span class="pub-pr-count">2</span>
              <span class="pub-pr-desc">Migración 16.0 · mejora en server-ux</span>
            </div>
          </div>
        </div>

        <div class="public-group">
          <h3>Otros repos públicos <span class="pub-total">~72</span></h3>
          <div class="pub-pr-list">
            <div class="pub-pr">
              <a href="https://github.com/CLaurelB/odoo_getting_started_16.0" target="_blank" class="pub-pr-link">CLaurelB/odoo_getting_started_16.0</a>
              <span class="pub-pr-count">~16</span>
              <span class="pub-pr-desc">Material de aprendizaje Odoo 16 (chapters + estate)</span>
            </div>
            <div class="pub-pr">
              <a href="https://github.com/odoo/upgrade-util/pull/107" target="_blank" class="pub-pr-link">odoo/upgrade-util</a>
              <span class="pub-pr-count">1</span>
              <span class="pub-pr-desc">Bugfix en utilidades de migración</span>
            </div>
            <div class="pub-pr">
              <span class="pub-pr-link">Otros (CybroAddons, avoinsystems, etc.)</span>
              <span class="pub-pr-count">~55</span>
              <span class="pub-pr-desc">Issues, forks, PRs menores y forward-ports automáticos</span>
            </div>
          </div>
        </div>

        <div class="public-summary">
          <p>Tasa de merge en aportes públicos: <strong>78.7%</strong></p>
        </div>
      </div>

      <div class="section-card">
        <h2>226 revisiones técnicas realizadas</h2>
        <div class="review-section">
          <p class="review-intro">MRs/PRs donde participé como reviewer formal o mediante LGTM.</p>
          <div class="review-bar">
            <span class="rev-label">ircanada/ircodoo <span class="rev-badge">priv</span></span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:83.2%"></div></div>
            <span class="rev-count">188</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">Vauxoo (int.) <span class="rev-badge">priv</span></span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:7.5%"></div></div>
            <span class="rev-count">17</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">GitHub.com <span class="rev-badge pub">pub</span></span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:4%"></div></div>
            <span class="rev-count">9</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">apps-purchased <span class="rev-badge">priv</span></span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:3.5%"></div></div>
            <span class="rev-count">8</span>
          </div>
          <div class="review-bar">
            <span class="rev-label">ircodoo-dev <span class="rev-badge">priv</span></span>
            <div class="bar-track"><div class="bar-fill rev-fill" style="width:1.8%"></div></div>
            <span class="rev-count">4</span>
          </div>
        </div>
      </div>

      <div class="gist-link">
        <p>¿Quieres ver el desglose completo con los 822 PRs/MRs, fechas y enlaces?</p>
        <a href="https://gist.github.com/Christihan-LB/2d7c7729d02ac56cefa4d0d5e0cedc94" target="_blank" class="btn btn-primary">
          Ver Gist completo →
        </a>
      </div>
    </div>
  </main>
</Base>

<style>
  .contrib-page {
    padding: 120px 0 64px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 48px;
  }

  .stats-banner {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .review-stat {
    border-color: #22c55e !important;
  }

  .review-stat .big-num {
    color: #22c55e !important;
  }

  .big-stat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 16px;
    text-align: center;
  }

  .big-num {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .big-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .section-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    margin-bottom: 24px;
  }

  .section-card h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .type-bars {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .type-bar {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .type-label {
    width: 100px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .bar-track {
    flex: 1;
    height: 12px;
    background: var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 6px;
  }

  .type-count {
    width: 48px;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .module-list, .repo-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .module-item, .repo-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 16px;
    background: var(--bg);
    border-radius: 8px;
  }

  .module-name, .repo-name {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .module-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 700;
  }

  .repo-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 700;
  }

  .repo-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .review-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .review-intro {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .review-bar {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .rev-label {
    width: 160px;
    font-size: 0.85rem;
    font-weight: 500;
    text-align: right;
    flex-shrink: 0;
  }

  .rev-count {
    width: 48px;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #22c55e;
    font-weight: 700;
  }

  .rev-fill {
    background: #22c55e !important;
  }

  .rev-badge {
    font-size: 0.6rem;
    padding: 1px 5px;
    border-radius: 3px;
    font-weight: 600;
    font-family: var(--font-mono);
    vertical-align: middle;
    margin-left: 4px;
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }

  .rev-badge.pub {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  .oca-list {
    list-style: none;
    padding: 0;
  }

  .oca-list li {
    padding: 8px 0;
    font-size: 0.95rem;
    border-bottom: 1px solid var(--border);
  }

  .oca-list li:last-child {
    border-bottom: none;
  }

  .oca-list li strong {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .gist-link {
    text-align: center;
    padding: 40px 0;
  }

  .gist-link p {
    color: var(--text-secondary);
    margin-bottom: 20px;
  }

  .section-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .public-group {
    margin-bottom: 32px;
  }

  .public-group h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .pub-total {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    margin-left: 8px;
  }

  .pub-pr-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pub-pr {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 6px 10px;
    font-size: 0.85rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .pub-pr:hover {
    background: rgba(99, 102, 241, 0.04);
  }

  .pub-pr-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    min-width: 200px;
  }

  .pub-pr-link:hover {
    text-decoration: underline;
  }

  .pub-pr-count {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
    min-width: 40px;
  }

  .pub-pr-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .pub-pr-desc a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border);
  }

  .pub-pr-desc a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .pub-gist-link {
    margin-top: 10px;
    font-size: 0.82rem;
  }

  .pub-gist-link a {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 600;
  }

  .pub-gist-link a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .public-summary {
    margin-top: 24px;
    padding: 14px 18px;
    background: rgba(99, 102, 241, 0.05);
    border-radius: 8px;
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .public-summary strong {
    color: var(--accent);
  }

  .repo-section-label {
    margin-bottom: 10px;
  }

  .repo-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-mono);
  }

  .repo-badge.private {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }

  .repo-badge.public {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }

  @media (max-width: 768px) {
    .stats-banner {
      grid-template-columns: repeat(3, 1fr);
    }

    .public-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .stats-banner {
      grid-template-columns: repeat(2, 1fr);
    }
