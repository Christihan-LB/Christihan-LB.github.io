>
  <Header />
  <main>
    <Hero />
    <About />
    <Services />
    <AutomationDemo />
    <Timeline />
    <Projects />
    <Media />
    <Publications />
    <Blog />
    <Contact />
  </main>
  <Footer />
</Base>
