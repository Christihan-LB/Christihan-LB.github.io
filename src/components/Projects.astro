<script>
  // Filter
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll('.project-card').forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  // Scroll animation
  document.querySelectorAll('.reveal').forEach(el => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = parseInt(el.style.transitionDelay) || 0;
            setTimeout(() => el.classList.add('visible'), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    observer.observe(el);
  });

  // Public/Private toggle — solo cambia números, sin saltos de layout
  const contribTotal = document.getElementById('contribTotal');
  const statLine = document.getElementById('statLine');
  const s = {
    n1: document.getElementById('s1n'), l1: document.getElementById('s1l'),
    n2: document.getElementById('s2n'), l2: document.getElementById('s2l'),
    n3: document.getElementById('s3n'), l3: document.getElementById('s3l'),
    n4: document.getElementById('s4n'), l4: document.getElementById('s4l'),
  };
  const bars = {
    vauxoo: document.getElementById('barVauxoo'),
    github: document.getElementById('barGitHub'),
    gitlab: document.getElementById('barGitLab'),
  };
  const verDetalle = document.querySelector('.ver-detalle');

  const viewData = {
    total: { num: '822', line: '647 fusionadas · 78.7% aceptación · 226 revisiones técnicas',
      n: ['410','185','85','40'], l: ['Mejoras','Bugfixes','Migraciones','Features'], link: '', linkText: '' },
    privado: { num: '629', line: 'Vauxoo (466) + ircanada (163) · 76.5% del total',
      n: ['466','163','~30','100%'], l: ['Git Vauxoo','ircanada/ircodoo','Desarrolladores','Merge interno'], link: '', linkText: '' },
    publico: { num: '193', line: 'GitHub público · 23.5% del total',
      n: ['44','~77','72','78.7%'], l: ['Odoo core+ee','OCA (10 repos)','Otros públicos','Merge rate'], link: '/contribuciones#publicos', linkText: 'Ver detalle de aportes públicos →' },
  };

  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const view = viewData[btn.dataset.view];
      contribTotal.textContent = view.num;
      statLine.textContent = view.line;
      s.n1.textContent = view.n[0]; s.l1.textContent = view.l[0];
      s.n2.textContent = view.n[1]; s.l2.textContent = view.l[1];
      s.n3.textContent = view.n[2]; s.l3.textContent = view.l[2];
      s.n4.textContent = view.n[3]; s.l4.textContent = view.l[3];

      if (verDetalle) {
        if (view.link) {
          verDetalle.href = view.link;
          verDetalle.textContent = view.linkText;
          verDetalle.style.display = '';
        } else {
          verDetalle.style.display = 'none';
        }
      }

      Object.entries(bars).forEach(([key, el]) => {
        el.style.opacity = btn.dataset.view === 'total' ? '1' : btn.dataset.view === 'privado' && (key === 'vauxoo' || key === 'gitlab') ? '1' : btn.dataset.view === 'publico' && key === 'github' ? '1' : '0.35';
      });
    });
  });
</script>
