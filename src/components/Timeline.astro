<style>
  .timeline {
    position: relative;
    max-width: 700px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding-left: 40px;
    padding-bottom: 48px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: -6px;
    top: 4px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--bg);
  }

  .timeline-date {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .timeline-content h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 6px 0 4px;
  }

  .timeline-org {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .timeline-body p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .timeline-detail {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease-out;
  }

  .timeline-detail.open {
    max-height: 200px;
  }

  .timeline-detail p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    padding: 2px 0;
  }

  .timeline-toggle {
    background: none;
    border: none;
    color: var(--accent);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 6px 0 0;
    transition: color 0.2s;
  }

  .timeline-toggle:hover {
    color: var(--accent-hover);
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .timeline-item {
      padding-left: 28px;
      padding-bottom: 36px;
    }
    .timeline-marker {
      left: -4px;
      width: 12px;
      height: 12px;
    }
    .timeline-content h3 {
      font-size: 1rem;
    }
    .timeline-body p {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.timeline-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const detail = btn.parentElement.querySelector('.timeline-detail');
      const isOpen = detail.classList.toggle('open');
      btn.textContent = isOpen ? 'Ver menos' : 'Ver más';
    });
  });

  document.querySelectorAll('.reveal').forEach(el => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = parseInt(el.style.transitionDelay) || 0;
            setTimeout(() => el.classList.add('visible'), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    observer.observe(el);
  });
</script>
